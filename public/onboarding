<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>La Curaduría · Bienvenida</title>
<meta name="description" content="La enciclopedia cultural. Una plataforma que enlaza eventos, perfiles y contenidos en una experiencia de navegación relacional.">
<meta property="og:title" content="La Curaduría · Conoce el proyecto">
<meta property="og:description" content="La enciclopedia cultural. Una plataforma relacional para explorar arte y cultura.">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,700&family=Barlow:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --coral:#FF736C;
  --cyan:#75E6F9;
  --green:#00AA74;
  --bg:#070908;--surf:#131813;--surf2:#181E18;
  --bord:#202820;--bord2:#2A342A;
  --cream:#F0F4EC;--t2:#C8DCC4;--t3:#A8C8A4;--t4:#7E9E7A;
}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--cream);font-family:'Barlow',sans-serif;}

/* NOISE */
.noise{position:fixed;inset:0;pointer-events:none;z-index:0;opacity:.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:200px;}

/* LOGO TOP */
.logo-top{
  display:flex;justify-content:center;align-items:center;
  padding-top:36px;padding-bottom:0;flex-shrink:0;
}

/* SLIDES */
.slides{width:100%;height:100%;position:relative;overflow:hidden;z-index:1;}

.slide{
  position:absolute;inset:0;
  display:flex;flex-direction:column;
  padding:0 28px 32px;
  opacity:0;transform:translateX(40px);
  transition:opacity .45s cubic-bezier(.4,0,.2,1),transform .45s cubic-bezier(.4,0,.2,1);
  pointer-events:none;overflow-y:auto;
}
.slide.active{opacity:1;transform:translateX(0);pointer-events:all;}
.slide.exit{opacity:0;transform:translateX(-40px);pointer-events:none;}

/* PROGRESS */
.progress{display:flex;gap:6px;padding-top:16px;flex-shrink:0;}
.dot{height:3px;border-radius:2px;background:var(--bord2);transition:all .4s;flex:1;}
.dot.done{background:var(--t4);}
.dot.active{background:var(--coral);}

/* BODY */
.slide-body{flex:1;display:flex;flex-direction:column;justify-content:center;padding:24px 0 16px;}

/* ANIM BASE */
.anim{opacity:0;transform:translateY(14px);transition:opacity .5s ease,transform .5s ease;}
.slide.active .anim{opacity:1;transform:translateY(0);}
.d1{transition-delay:.15s;}.d2{transition-delay:.25s;}.d3{transition-delay:.35s;}.d4{transition-delay:.45s;}.d5{transition-delay:.55s;}

/* S1 LOGO */
.s1-logo-wrap{margin-bottom:26px;}

/* TITLES */
.s1-title{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;
  font-size:clamp(38px,10vw,58px);line-height:.96;letter-spacing:-.01em;
  color:var(--cream);margin-bottom:20px;
}
.s1-title span{color:var(--coral);font-style:italic;}

.slide-heading{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;
  font-size:clamp(28px,7.5vw,46px);line-height:1.04;letter-spacing:-.01em;
  color:var(--cream);margin-bottom:20px;
}
.c-coral{color:var(--coral);}
.c-cyan{color:var(--cyan);}
.c-green{color:var(--green);}

.s1-desc{font-size:15px;line-height:1.65;color:var(--t3);max-width:320px;}

/* ── SLIDE 2: PESTAÑAS SIMPLES ── */
.tabs-simple{
  display:flex;gap:0;margin-bottom:0;
}
.tab-s{
  padding:8px 16px;
  font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.13em;text-transform:uppercase;
  border-width:1px;border-style:solid;border-bottom:none;
  border-radius:6px 6px 0 0;font-weight:500;
  cursor:default;
}
.tab-s.coral{background:rgba(255,115,108,.1);color:var(--coral);border-color:rgba(255,115,108,.3);}
.tab-s.cyan{background:rgba(117,230,249,.08);color:var(--cyan);border-color:rgba(117,230,249,.25);}
.tab-s.green{background:rgba(0,170,116,.08);color:var(--green);border-color:rgba(0,170,116,.22);}

.tabs-panel{
  padding:18px 16px;
  background:var(--surf);
  border:1px solid var(--bord2);
  border-radius:0 10px 10px 10px;
}

.tabs-desc{
  font-size:14px;line-height:1.6;color:var(--t3);
}

/* ── SLIDE 3: ACCIONES como fila horizontal ── */
.action-row{
  display:flex;flex-direction:column;gap:0;
  border:1px solid var(--bord2);border-radius:10px;overflow:hidden;
}
.action-item{
  display:flex;align-items:center;gap:14px;
  padding:14px 16px;
  border-bottom:1px solid var(--bord);
}
.action-item:last-child{border-bottom:none;}
.action-dot{
  width:8px;height:8px;border-radius:50%;flex-shrink:0;
}
.action-label{
  font-size:14px;font-weight:600;color:var(--cream);flex:1;
}
.action-sub{
  font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.1em;text-transform:uppercase;color:var(--t4);
}

.scraping-note{
  margin-top:12px;
  padding:11px 14px;
  background:var(--surf2);
  border:1px solid var(--bord);
  border-radius:8px;
  font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--t4);
  display:flex;align-items:center;gap:8px;
}
.scraping-note span{color:var(--t2);}

/* PILLS */
.pill-row{
  display:flex;flex-wrap:wrap;gap:7px;margin-top:20px;
}
.pill{
  display:inline-flex;align-items:center;padding:6px 13px;border-radius:20px;
  font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;
  border:1px solid var(--bord2);color:var(--t3);
}
.pill.coral{border-color:rgba(255,115,108,.3);color:var(--coral);background:rgba(255,115,108,.06);}
.pill.cyan{border-color:rgba(117,230,249,.3);color:var(--cyan);background:rgba(117,230,249,.06);}
.pill.green{border-color:rgba(0,170,116,.3);color:var(--green);background:rgba(0,170,116,.06);}

/* LOGO BOTTOM */
.logo-bottom{display:flex;align-items:center;margin-bottom:16px;flex-shrink:0;}

/* ACTIONS */
.slide-actions{display:flex;flex-direction:column;gap:8px;flex-shrink:0;}

.btn-primary{
  width:100%;padding:15px;background:var(--coral);color:#070908;
  border:none;border-radius:8px;
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:17px;
  letter-spacing:.04em;text-transform:uppercase;cursor:pointer;
  transition:background .15s,transform .1s;text-align:center;text-decoration:none;display:block;
}
.btn-primary:hover{background:#ff5e56;}
.btn-primary:active{transform:scale(.98);}

.btn-outline{
  width:100%;padding:14px;background:transparent;color:var(--cyan);
  border:1px solid rgba(117,230,249,.3);border-radius:8px;
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;
  letter-spacing:.04em;text-transform:uppercase;cursor:pointer;
  transition:.15s;text-align:center;text-decoration:none;display:block;
}
.btn-outline:hover{background:rgba(117,230,249,.06);border-color:rgba(117,230,249,.5);}

.btn-secondary{
  width:100%;padding:12px;background:transparent;color:var(--t4);
  border:1px solid var(--bord2);border-radius:8px;
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;
  cursor:pointer;transition:.15s;text-align:center;text-decoration:none;display:block;
}
.btn-secondary:hover{color:var(--cream);border-color:rgba(240,244,236,.2);}
</style>
</head>
