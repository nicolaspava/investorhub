<script>
let current = 0;
const total = 4;
let startX = 0;
let isDragging = false;

function goTo(n){
  if(n < 0 || n >= total) return;
  const slides = document.querySelectorAll('.slide');
  slides[current].classList.remove('active');
  slides[current].classList.add('exit');
  setTimeout(()=>{ slides[current].classList.remove('exit'); }, 450);
  current = n;
  slides[current].classList.add('active');
  updateProgress();
}
function goNext(){ goTo(current + 1); }
function goPrev(){ goTo(current - 1); }

function updateProgress(){
  const slides = document.querySelectorAll('.slide');
  slides.forEach((slide, si) => {
    slide.querySelectorAll('.dot').forEach((dot, di) => {
      dot.className = 'dot';
      if(di < si) dot.classList.add('done');
      else if(di === si) dot.classList.add('active');
    });
  });
}

document.addEventListener('touchstart', e => { startX = e.touches[0].clientX; isDragging = true; }, { passive: true });
document.addEventListener('touchend', e => {
  if(!isDragging) return;
  const dx = e.changedTouches[0].clientX - startX;
  if(Math.abs(dx) > 50){ dx < 0 ? goNext() : goPrev(); }
  isDragging = false;
}, { passive: true });
document.addEventListener('keydown', e => {
  if(e.key === 'ArrowRight' || e.key === ' ') goNext();
  if(e.key === 'ArrowLeft') goPrev();
});
</script>
